# GEMINI_API_KEY: server-side key for the "Ask Aether" demo agent.
# Used ONLY by the /api/agent proxy (Vite dev middleware locally; Cloudflare
# Pages Function in production). It is NEVER exposed in the browser bundle.
# Local dev: copy this file to .env and set the real key.
# Production: set GEMINI_API_KEY as a Pages secret (do NOT commit it).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: optional override. Defaults to gemini-2.5-flash (supports function calling).
# GEMINI_MODEL="gemini-2.5-flash"

# APP_URL: optional. The URL where this microsite is hosted (self-referential links).
APP_URL="MY_APP_URL"
