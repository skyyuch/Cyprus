# ANTHROPIC_API_KEY: server-side key for the "Ask Aether" demo agent (Claude).
# Used ONLY by the /api/agent proxy (Vite dev middleware locally; Cloudflare
# Pages Function in production). It is NEVER exposed in the browser bundle.
# Local dev: copy this file to .env and set the real key.
# Production: set ANTHROPIC_API_KEY as a Pages secret (do NOT commit it).
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# ANTHROPIC_MODEL: optional override. Defaults to claude-sonnet-4-5.
# ANTHROPIC_MODEL="claude-sonnet-4-5"

# APP_URL: optional. The URL where this microsite is hosted (self-referential links).
APP_URL="MY_APP_URL"
